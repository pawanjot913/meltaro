# ── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
# Your MongoDB Atlas connection string
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/meltaro?retryWrites=true&w=majority
MONGODB_URI=

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Include Netlify when deploying the frontend there.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://melatro.netlify.app

# ── Auth — Access Token (short-lived, sent in response body) ─────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m

# ── Auth — Refresh Token (long-lived, stored in httpOnly cookie) ──────
# Must be DIFFERENT from JWT_SECRET
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie signing ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# ── Admin seed account ────────────────────────────────────────────────
# Created by: npm run seed
# Use these credentials to call POST /api/auth/login
ADMIN_EMAIL=admin
ADMIN_PASSWORD=Admin

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Third-party APIs ──────────────────────────────────────────────────
# Free Gemini API key for the Mello chatbot (Google AI Studio).
# Get one: https://aistudio.google.com/apikey
# Leave empty to use offline canned replies.
GEMINI_API_KEY=

# ── Supabase Auth (customer JWT verification via JWKS) ────────────────
# Project Settings → API → Project URL only.
# Access tokens are verified with the public JWKS at:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Do NOT use the legacy JWT secret — signing keys are asymmetric (ECC P-256).
SUPABASE_URL=https://your-project.supabase.co
