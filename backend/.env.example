# ── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
# Your MongoDB Atlas connection string
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/meltaro?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://pawanjot913_db_user:4bwhJGh2EKOXZ2F5@cluster0.fgrwfrb.mongodb.net/?appName=Cluster0

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Auth — Access Token (short-lived, sent in response body) ─────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=2da83f12add388591e30030d9658cc30327cbc89b47b224e0ad7846284d72e3102ad0c23dcae5b30056d3e4729beb17f
JWT_EXPIRES_IN=15m

# ── Auth — Refresh Token (long-lived, stored in httpOnly cookie) ──────
# Must be DIFFERENT from JWT_SECRET
JWT_REFRESH_SECRET=ad9a75c7486ae7bf612a589c601e65de9bb5c7a900f00770d6919246042210b3531550f934e410dc333695aa01712121
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie signing ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=76d7b50756bc72c94c577de468880eada32fbae42b10b9ee1489c5d72abbc506

# ── Admin seed account ────────────────────────────────────────────────
# Created by: npm run seed
# Use these credentials to call POST /api/auth/login
ADMIN_EMAIL=admin@meltarocafe.com
ADMIN_PASSWORD=Admin@123

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Third-party APIs ──────────────────────────────────────────────────
# Free Gemini API key for the Mello chatbot (Google AI Studio).
# Get one: https://aistudio.google.com/apikey
# Leave empty to use offline canned replies.
GEMINI_API_KEY=

# ── Supabase Auth (customer JWT verification via JWKS) ────────────────
# Project Settings → API → Project URL only.
# Access tokens are verified with the public JWKS at:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Do NOT use the legacy JWT secret — signing keys are asymmetric (ECC P-256).
SUPABASE_URL=https://your-project.supabase.co
