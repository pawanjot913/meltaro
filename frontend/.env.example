# Base URL of the backend API. Leave empty in development — Vite's dev
# server proxies /api/* to VITE_API_PROXY_TARGET (see vite.config.ts).
# Set this to your deployed backend's URL in production, e.g.:
# VITE_API_URL=https://api.meltarocafe.com
VITE_API_URL=

# Only used by vite.config.ts during `npm run dev` to know where to proxy
# /api/* requests. Defaults to http://localhost:5000 if unset.
VITE_API_PROXY_TARGET=http://localhost:5000

# ── Supabase Auth (customer login for placing orders) ─────────────────
# Project Settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
